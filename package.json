{
  "name": "onclaw",
  "version": "0.1.5",
  "description": "AI-powered SaaS customization — let users reshape your app with natural language. One line of code.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "onclaw": "./dist/cli/init.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "cd demo && npm run dev",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react",
    "nextjs",
    "ai",
    "customization",
    "saas",
    "component-generation",
    "cmd-k",
    "command-palette"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZohaibAhmed/onclaw"
  },
  "homepage": "https://github.com/ZohaibAhmed/onclaw#readme",
  "bugs": {
    "url": "https://github.com/ZohaibAhmed/onclaw/issues"
  },
  "author": "Zohaib Ahmed <zohaib@resemble.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
